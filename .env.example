# Fam Tree Bot - Environment Configuration
# =========================================
# Copy this file to .env and fill in your values

# Required: Your Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# Optional: Database URL (default: SQLite)
# DATABASE_URL=sqlite:///fam_tree_bot.db
# DATABASE_URL=postgresql://user:password@localhost/fam_tree_bot

# Optional: Admin User IDs (comma-separated)
ADMIN_USER_IDS=123456789,987654321

# Optional: Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: OpenAI API Key (for AI features)
# OPENAI_API_KEY=your_openai_key_here

# Optional: Blockchain RPC URL (for crypto features)
# ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your_project_id

# Optional: Weather API Key
# WEATHER_API_KEY=your_weather_api_key

# Optional: Redis URL (for caching)
# REDIS_URL=redis://localhost:6379/0
